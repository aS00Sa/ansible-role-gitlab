#!/usr/bin/env bash
set -euo pipefail

LOCK_FILE="{{ gitlab_self_service_registry_gc_lock_file }}"
LOG_FILE="{{ gitlab_self_service_registry_gc_log_file }}"

mkdir -p "$(dirname "$LOCK_FILE")" "$(dirname "$LOG_FILE")"
touch "$LOG_FILE"

exec 9>"$LOCK_FILE"
if ! flock -n 9; then
  echo "[$(date -Is)] SKIP registry-gc (already running)" >> "$LOG_FILE"
  exit 0
fi

{
  echo "[$(date -Is)] START registry-gc"
  gitlab-ctl registry-garbage-collect
  echo "[$(date -Is)] DONE registry-gc"
} >> "$LOG_FILE" 2>&1
